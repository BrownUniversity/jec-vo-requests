{
  "appName": "JEC VO Requests",
  "baseUrl" : "https://api.atlassian.com",
  "logLevel" : "INFO",
  "globalArgs": [],
  "globalFlags": {
    "notificationEmail": "Sean_Broestl@brown.edu"
  },
  "globalEnv": [
    "GOOGLE_APPLICATION_CREDENTIALS=/mnt/google-credentials",
    "UV_CACHE_DIR=/tmp/uv-cache",
    "PATH=$PATH:/usr/local/bin:/usr/bin:/bin"
  ],
  "actionMappings" : {
    "create_gcp_project" : {
        "sourceType" : "git",
        "gitOptions" : {
            "url" : "https://github.com/BrownUniversity/jec-vo-requests.git"
        },
        "filepath" : "scripts/create_gcp_project.py",
        "Stderr": "/tmp/action_logs/create_gcp_project_jecErr.log",
        "Stdout": "/tmp/action_logs/create_gcp_project_jecOut.log"
    },
    "create_bcs_token": {
        "sourceType" : "git",
        "gitOptions" : {
            "url" : "https://github.com/BrownUniversity/jec-vo-requests.git"
        },
        "filepath": "scripts/create_bcs_token.sh",
        "Stderr": "logs/create_bcs_token_jecErr.log",
        "Stdout": "logs/create_bcs_token_jecOut.log"
    },
    "test_action": {
        "sourceType" : "git",
        "gitOptions" : {
            "url" : "https://github.com/BrownUniversity/jec-vo-requests.git"
        },
        "args":
        [
          "boilerplate.py"
        ],
        "filepath": "scripts/uv_wrapper.sh",
        "Stderr": "/tmp/action_logs/test_action_jecErr.log",
        "Stdout": "/tmp/action_logs/test_action_jecOut.log"
    }
  },
  "pollerConf" : {
    "pollingWaitIntervalInMillis" : 100,
    "visibilityTimeoutInSeconds" : 30,
    "maxNumberOfMessages" : 10
  },
  "poolConf" : {
    "maxNumberOfWorker": 1,
    "minNumberOfWorker": 1,
    "queueSize" : 0,
    "keepAliveTimeInMillis" : 6000,
    "monitoringPeriodInMillis" : 15000
  }
}